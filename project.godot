config_version=5

[application]

config/name="BibleWorld Kids"
config/description="Jeu mobile chretien pour enfants 4-12 ans"
run/main_scene="res://_Game/Scenes/Boot.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[autoload]

Constantes="*res://autoloads/Constantes.gd"
SystemeSauvegarde="*res://autoloads/SystemeSauvegarde.gd"
GameManager="*res://autoloads/GameManager.gd"
ChargeurScene="*res://autoloads/ChargeurScene.gd"
GestionnaireInput="*res://autoloads/GestionnaireInput.gd"
GestionnaireAudio="*res://autoloads/GestionnaireAudio.gd"
SystemeDialogues="*res://autoloads/SystemeDialogues.gd"
Inventaire="*res://_Game/Scripts/Joueur/Inventaire.gd"
GestionnaireQuetes="*res://_Game/Scripts/Quetes/GestionnaireQuetes.gd"
UINotifications="*res://autoloads/UINotifications.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/resizable=false

[input]

action_principale={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"echo":false,"script":null), Object(InputEventScreenTouch,"resource_local_to_scene":false,"resource_name":"","device":-1,"index":0,"position":Vector2(0, 0),"double_tap":false,"pressed":false,"script":null)]
}
action_secondaire={
